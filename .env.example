# App (optional — links in emails auto-detect from the live request domain)
# APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Spark

# Database (PostgreSQL)
DATABASE_URL="postgresql://spark:spark@localhost:5433/spark?schema=public"

# Redis (optional caching)
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="spark-dev-jwt-secret-minimum-32-characters-long"
JWT_REFRESH_SECRET="spark-dev-refresh-secret-minimum-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth (Step 2)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# File Storage — local for dev; appwrite or r2 in production (see production.env.example)
STORAGE_PROVIDER=local
NEXT_PUBLIC_STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
NEXT_PUBLIC_UPLOAD_URL=/uploads

# Appwrite (production)
# APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=
# APPWRITE_API_KEY=
# APPWRITE_BUCKET_ID=6a4362790030c2e1da0b

# R2 (alternative)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=spark-media

# Web Push (future)
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@spark.app"

# Stripe (future - Step 8)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Email (Gmail SMTP — use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=yourgmail@gmail.com

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# SENTRY_DSN=
ADMIN_EMAILS="rounak153d@gmail.com"
