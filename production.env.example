# Spark — Production Environment Variables (Neon + Appwrite + Vercel)

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Spark
NEXT_PUBLIC_STORAGE_PROVIDER=appwrite

# ── Database (Neon pooled URL) ─────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-another-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (required for registration verification) ───────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=yourgmail@gmail.com

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAILS=admin@yourdomain.com

# ── Appwrite Cloud Storage ───────────────────────────────────
STORAGE_PROVIDER=appwrite
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_api_key_with_storage_scope
APPWRITE_BUCKET_ID=your_bucket_id

# ── Upstash Redis (distributed rate limiting — recommended) ──
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Sentry (error monitoring — optional) ─────────────────────
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
# SENTRY_ORG=your-org
# SENTRY_PROJECT=spark
